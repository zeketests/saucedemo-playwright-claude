{
  "name": "saucedemo-playwright-claude",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:clean": "rm -rf allure-results allure-report",
    "test:allure": "playwright test && npm run allure:generate"
  },
  "keywords": [],
  "author": "Zeke",
  "license": "ISC",
  "description": "A Playwright test suite for SauceDemo created with help from Claude.",
  "devDependencies": {
    "@playwright/cli": "^0.1.5",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0"
  }
}
